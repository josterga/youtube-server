[Unit]
Description=Media Ingest Worker
After=network.target media-app.service

[Service]
Type=simple
User=media
WorkingDirectory=/srv/media-ingest
EnvironmentFile=/srv/media-ingest/.env
ExecStart=/srv/media-ingest/venv/bin/python -m app.worker
Restart=always
RestartSec=10
Nice=10
IOSchedulingClass=3

[Install]
WantedBy=multi-user.target
